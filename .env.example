# ─────────────────────────────────────────────
# SUPABASE (obrigatório)
# ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# REDIS / UPSTASH (cache + BullMQ)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxx
REDIS_URL=redis://default:password@localhost:6379

# ─────────────────────────────────────────────
# META ADS API
# ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# GOOGLE ADS API
# ─────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ─────────────────────────────────────────────
# H3 CRM (API interna)
# ─────────────────────────────────────────────
H3_CRM_BASE_URL=https://crm.h3labs.com.br/api
H3_CRM_API_KEY=
H3_CRM_WEBHOOK_SECRET=  # HMAC-SHA256 para validar webhooks

# ─────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
JWT_SECRET=                  # apenas para dev local; prod usa Supabase JWT
ENCRYPTION_KEY=              # 32 bytes hex para AES-256-GCM (PII)

# ─────────────────────────────────────────────
# AUTH SSO (Google OAuth para time H3)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_CALLBACK_URL=http://localhost:3001/auth/sso/google/callback

# ─────────────────────────────────────────────
# OBSERVABILIDADE
# ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=h3-dashboard-api
SENTRY_DSN=                  # opcional
